<Window x:Class="CodexUsageWidget.AppearanceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Codex 额度 · 外观设置"
        Width="430"
        Height="660"
        MinWidth="430"
        MinHeight="560"
        MaxWidth="430"
        MaxHeight="720"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="#FF191C23"
        FontFamily="{StaticResource UiFont}"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closed="Window_Closed">
    <Window.Resources>
        <SolidColorBrush x:Key="SettingsText" Color="#FFF5F7FA" />
        <SolidColorBrush x:Key="SettingsMuted" Color="#FF98A2B3" />

        <Style x:Key="SettingsButton" TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="13,0" />
            <Setter Property="Background" Value="#FF2B303C" />
            <Setter Property="Foreground" Value="{StaticResource SettingsText}" />
            <Setter Property="BorderBrush" Value="#FF414856" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#FF363C49" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.78" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SwatchButton" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="BorderBrush" Value="#66FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Swatch"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Swatch" Property="BorderBrush" Value="White" />
                                <Setter TargetName="Swatch" Property="BorderThickness" Value="2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HexTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="9,5" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="#FF222630" />
            <Setter Property="Foreground" Value="{StaticResource SettingsText}" />
            <Setter Property="CaretBrush" Value="White" />
            <Setter Property="BorderBrush" Value="#FF414856" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="SettingsComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Foreground" Value="{StaticResource SettingsText}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemChrome"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#FF363C49" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#334B82F6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="Background" Value="#FF222630" />
            <Setter Property="Foreground" Value="{StaticResource SettingsText}" />
            <Setter Property="BorderBrush" Value="#FF414856" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource SettingsComboBoxItem}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False"
                                          ClickMode="Press"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8">
                                    <Grid Margin="10,0,8,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="14" />
                                        </Grid.ColumnDefinitions>
                                        <ContentPresenter VerticalAlignment="Center"
                                                          Content="{TemplateBinding SelectionBoxItem}"
                                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                                        <Path Grid.Column="1"
                                              Width="8"
                                              Height="5"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Center"
                                              Data="M 0,0 L 4,5 L 8,0 Z"
                                              Fill="{TemplateBinding Foreground}" />
                                    </Grid>
                                </Border>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,3,0,0"
                                        Padding="4"
                                        Background="#FF222630"
                                        BorderBrush="#FF414856"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <ScrollViewer CanContentScroll="True">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource SettingsText}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="22,18,22,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="38" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0"
                      Margin="0,0,-8,0"
                      Padding="0,0,8,0"
                      VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource SettingsText}"
                       Text="外观设置" />
            <TextBlock Margin="0,3,0,17"
                       FontSize="11"
                       Foreground="{StaticResource SettingsMuted}"
                       Text="也可以直接拖动主窗口的任意边或角进行拉伸。" />

            <TextBlock FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource SettingsText}"
                       Text="显示内容" />
            <Grid Margin="0,8,0,7">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="76" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center"
                           Foreground="{StaticResource SettingsMuted}"
                           Text="额度风格" />
                <ComboBox x:Name="ViewStyleComboBox"
                          Grid.Column="1"
                          SelectedIndex="1"
                          Style="{StaticResource SettingsComboBox}">
                    <ComboBoxItem Tag="Card" Content="卡片视图" />
                    <ComboBoxItem Tag="Ring" Content="环形视图" />
                </ComboBox>
            </Grid>
            <CheckBox x:Name="ShowTokenUsageCheckBox"
                      Margin="76,2,0,9"
                      IsChecked="True"
                      Style="{StaticResource SettingsCheckBox}"
                      Content="显示 Token 消耗统计" />
            <Grid Margin="0,0,0,7">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="76" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center"
                           Foreground="{StaticResource SettingsMuted}"
                           Text="累计周期" />
                <ComboBox x:Name="TokenPeriodComboBox"
                          Grid.Column="1"
                          SelectedIndex="1"
                          Style="{StaticResource SettingsComboBox}">
                    <ComboBoxItem Tag="SevenDays" Content="最近 7 天" />
                    <ComboBoxItem Tag="ThirtyDays" Content="最近 30 天" />
                    <ComboBoxItem Tag="NinetyDays" Content="最近 90 天" />
                    <ComboBoxItem Tag="All" Content="全部记录" />
                    <ComboBoxItem Tag="Custom" Content="自定义日期" />
                </ComboBox>
            </Grid>
            <Grid x:Name="CustomDatePanel"
                  Margin="76,0,0,15"
                  Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="22" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <DatePicker x:Name="CustomStartDatePicker"
                            Height="30"
                            ToolTip="累计开始日期" />
                <TextBlock Grid.Column="1"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource SettingsMuted}"
                           Text="至" />
                <DatePicker x:Name="CustomEndDatePicker"
                            Grid.Column="2"
                            Height="30"
                            ToolTip="累计结束日期" />
            </Grid>

            <TextBlock FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource SettingsText}"
                       Text="尺寸" />
            <Grid Margin="0,8,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="42" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="58" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Foreground="{StaticResource SettingsMuted}" Text="宽度" />
                <Slider x:Name="WidthSlider"
                        Grid.Column="1"
                        Minimum="160"
                        Maximum="720"
                        SmallChange="4"
                        LargeChange="20"
                        ValueChanged="SizeSlider_ValueChanged" />
                <TextBlock x:Name="WidthValueText"
                           Grid.Column="2"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource SettingsMuted}" />
            </Grid>
            <Grid Margin="0,4,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="42" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="58" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Foreground="{StaticResource SettingsMuted}" Text="高度" />
                <Slider x:Name="HeightSlider"
                        Grid.Column="1"
                        Minimum="120"
                        Maximum="520"
                        SmallChange="4"
                        LargeChange="20"
                        ValueChanged="SizeSlider_ValueChanged" />
                <TextBlock x:Name="HeightValueText"
                           Grid.Column="2"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource SettingsMuted}" />
            </Grid>
            <Grid Margin="0,4,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="62" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="58" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Foreground="{StaticResource SettingsMuted}" Text="透明度" />
                <Slider x:Name="OpacitySlider"
                        Grid.Column="1"
                        Minimum="50"
                        Maximum="100"
                        SmallChange="1"
                        LargeChange="5"
                        ValueChanged="OpacitySlider_ValueChanged" />
                <TextBlock x:Name="OpacityValueText"
                           Grid.Column="2"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource SettingsMuted}" />
            </Grid>

            <TextBlock FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource SettingsText}"
                       Text="强调色" />
            <WrapPanel Margin="0,8,0,8">
                <Button Tag="#10A37F" Background="#FF10A37F" Style="{StaticResource SwatchButton}" Click="AccentSwatch_Click" />
                <Button Tag="#3B82F6" Background="#FF3B82F6" Style="{StaticResource SwatchButton}" Click="AccentSwatch_Click" />
                <Button Tag="#8B5CF6" Background="#FF8B5CF6" Style="{StaticResource SwatchButton}" Click="AccentSwatch_Click" />
                <Button Tag="#F59E0B" Background="#FFF59E0B" Style="{StaticResource SwatchButton}" Click="AccentSwatch_Click" />
                <Button Tag="#EC4899" Background="#FFEC4899" Style="{StaticResource SwatchButton}" Click="AccentSwatch_Click" />
                <Button Tag="#06B6D4" Background="#FF06B6D4" Style="{StaticResource SwatchButton}" Click="AccentSwatch_Click" />
            </WrapPanel>
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="72" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="AccentHexTextBox" Style="{StaticResource HexTextBox}" />
                <Button Grid.Column="2"
                        Tag="Accent"
                        Style="{StaticResource SettingsButton}"
                        Click="ApplyHex_Click"
                        Content="应用" />
            </Grid>

            <TextBlock FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource SettingsText}"
                       Text="背景色" />
            <WrapPanel Margin="0,8,0,8">
                <Button Tag="#191C23" Background="#FF191C23" Style="{StaticResource SwatchButton}" Click="BackgroundSwatch_Click" />
                <Button Tag="#172033" Background="#FF172033" Style="{StaticResource SwatchButton}" Click="BackgroundSwatch_Click" />
                <Button Tag="#221933" Background="#FF221933" Style="{StaticResource SwatchButton}" Click="BackgroundSwatch_Click" />
                <Button Tag="#2A1B1B" Background="#FF2A1B1B" Style="{StaticResource SwatchButton}" Click="BackgroundSwatch_Click" />
                <Button Tag="#102725" Background="#FF102725" Style="{StaticResource SwatchButton}" Click="BackgroundSwatch_Click" />
                <Button Tag="#E8EDF5" Background="#FFE8EDF5" Style="{StaticResource SwatchButton}" Click="BackgroundSwatch_Click" />
            </WrapPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="72" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="BackgroundHexTextBox" Style="{StaticResource HexTextBox}" />
                <Button Grid.Column="2"
                        Tag="Background"
                        Style="{StaticResource SettingsButton}"
                        Click="ApplyHex_Click"
                        Content="应用" />
            </Grid>

            <TextBlock x:Name="ValidationText"
                       Height="20"
                       Margin="0,7,0,0"
                       FontSize="10.5"
                       Foreground="#FFFB7185" />
        </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Style="{StaticResource SettingsButton}"
                    Click="Reset_Click"
                    Content="恢复默认" />
            <Button Grid.Column="2"
                    Width="84"
                    Background="#FF10A37F"
                    BorderBrush="#FF10A37F"
                    Style="{StaticResource SettingsButton}"
                    Click="Done_Click"
                    Content="完成" />
        </Grid>
    </Grid>
</Window>
